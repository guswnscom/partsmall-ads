# Copy this to /opt/partsmall/.env on the production server and fill in.
# NEVER commit a real .env to git.

# Anthropic Claude API (for license disc OCR + Director Agent)
ANTHROPIC_API_KEY=
# OCR (license disc) — fast + cheap is fine
ANTHROPIC_MODEL=claude-haiku-4-5
# Ad copy generation — quality matters more
ANTHROPIC_COPY_MODEL=claude-sonnet-4-5

# OpenAI image generation (poster creation per variant). Optional — if missing,
# poster generation is disabled but copy generation still works.
OPENAI_API_KEY=
# gpt-image-1 (recommended) or dall-e-3
OPENAI_IMAGE_MODEL=gpt-image-1
# low | medium | high. high ($0.17/img ≈ R3.20) gives noticeably less AI-tell on
# product photography. Use medium ($0.04) for early prototyping only.
OPENAI_IMAGE_QUALITY=high

# Optional: USD->ZAR rate used for showing poster costs in admin UI in Rand.
# Default 19 if not set. Adjust to current FX rate periodically.
OPENAI_USD_TO_ZAR=19

# Domain & URLs
DOMAIN=psms-pmaad.co.za
LANDING_BASE_URL=https://psms-pmaad.co.za

# Admin password (Streamlit) — set strong, 16+ chars
ADMIN_PASSWORD=

# DB path (absolute)
DB_PATH=/opt/partsmall/data/partsmall.db

# Timezone
TIMEZONE=Africa/Johannesburg
